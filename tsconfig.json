{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "~/*": ["src/*"],
      "components/*": ["src/components/*"],
      "pages/*": ["src/pages/*"],
      "hooks/*": ["src/hooks/*"],
      "context/*": ["src/context/*"],
      "utils/*": ["src/utils/*"],
      "assets/*": ["src/assets/*"],
      "lib/*": ["src/lib/*"],
      "data/*": ["src/data/*"],
      "documents/*": ["src/documents/*"],
      "layout/*": ["src/layout/*"],
      "types/*": ["src/types/*"]
    }
  },
  "include": ["src"]
}
