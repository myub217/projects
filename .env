# =========================================
# ✅ PORT SETTING
# =========================================

# สำหรับรัน backend server (เช่น Express.js)
PORT=3000

# =========================================
# ✅ GOOGLE SHEET CONFIGURATION
# =========================================

# Endpoint สำหรับโหลดข้อมูลผู้ใช้จาก Google Sheet
# ใช้ร่วมกับ opensheet.vercel.app
# 👉 ตรวจสอบว่า Google Sheet เปิดสิทธิ์ "Anyone with the link"
OPEN_SHEET_ENDPOINT=https://opensheet.vercel.app/10MjcjWE03uS1SsDvsumN5PwpHjIWsyGkLa0h4Lx18zs/Sheet1

# =========================================
# ✅ ACCESS KEYS สำหรับการเข้าสู่ระบบแบบพิเศษ
# =========================================

# ใช้สำหรับเข้าสู่ระบบแบบเร่งด่วน (อาจใช้ในหน้า /login แบบ key-only)
VALID_ACCESS_KEYS=JPKYEKEY01,JPKYEKEY02,JPKYEKEY03,JPKYEKEY04,JPKYEKEY05,JPKYEKEY06,JPKYEKEY07,JPKYEKEY08,JPKYEKEY09,JPKYEKEY10